{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Flet App",
            "type": "shell",
            "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "args": ["${workspaceFolder}\\main.py"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "isBackground": false
        },
        {
            "label": "Install Dependencies",
            "type": "shell",
            "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "args": ["-m", "pip", "install", "-r", "${workspaceFolder}\\requirements.txt"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
